# Marktree Server Environment

# Database
DATABASE_URL=./data/marktree.db

# Better Auth
BETTER_AUTH_SECRET=your-better-auth-secret-min-32-characters-here
BETTER_AUTH_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Git repositories directory
GIT_REPOS_DIR=./data/repos

# Server port
PORT=3000

# AI / Kilo Gateway
# Get your API key from https://app.kilo.ai
# Model: stepfun/step-3.7-flash (Step Fun 3.7 Flash via Kilo Gateway)
KILO_API_KEY=your_kilo_gateway_api_key_here
KILO_BASE_URL=https://api.kilo.ai/api/gateway
AI_MODEL=stepfun/step-3.7-flash
